# 복사: copy .env.local.example .env.local  (Windows)
#
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보
# > OAuth 2.0 클라이언트 ID 만들기 > 유형: "웹 애플리케이션"
# > 승인된 JavaScript 출처: http://localhost:5173
#
# 아래 = 뒤에 "클라이언트 ID" 전체 붙여넣기 (클라이언트 보안 비밀 아님!)
# 따옴표 없이, 한 줄, 예: 987654321-abc123xyz.apps.googleusercontent.com

VITE_GOOGLE_CLIENT_ID=
